generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum TaskStatus {
  pending
  done
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  tasks Task[]
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  status      TaskStatus @default(pending)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userId      Int
  user        User       @relation(fields: [userId], references: [id])
}